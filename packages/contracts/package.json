{
  "name": "@liquidlp/contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "forge build",
    "test": "forge test --match-path 'test/unit/**' -vvv",
    "test:fork": "forge test --match-path 'test/fork/**' --fork-url $ETH_RPC_URL -vvv",
    "test:invariant": "forge test --match-path 'test/invariant/**' -vvv",
    "test:all": "forge test -vvv",
    "test:all:fork": "forge test --fork-url $ETH_RPC_URL -vvv",
    "test:e2e": "forge test --match-path 'test/e2e/**' --fork-url http://localhost:8545 -vvv",
    "test:docker": "forge test --fork-url http://localhost:8545 -vvv",
    "test:ci": "forge test --fork-url http://localhost:8545",
    "test:gas": "forge test --gas-report",
    "test:coverage": "forge coverage",
    "docker:fork": "cd ../.. && docker compose up -d anvil",
    "docker:fork:down": "cd ../.. && docker compose down",
    "fork:local": "anvil --fork-url $ETH_RPC_URL --block-time 12",
    "fork:base": "anvil --fork-url $BASE_RPC_URL --block-time 2",
    "fork:arb": "anvil --fork-url $ARB_RPC_URL --block-time 1",
    "snapshot": "forge snapshot",
    "lint": "solhint 'src/**/*.sol'",
    "lint:fix": "solhint 'src/**/*.sol' --fix",
    "fmt": "forge fmt",
    "fmt:check": "forge fmt --check",
    "clean": "forge clean"
  }
}
