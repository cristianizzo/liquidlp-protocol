{
  "name": "@liquidlp/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/api/index.ts",
    "dev:liquidator": "tsx watch src/services/liquidator/index.ts",
    "dev:monitor": "tsx watch src/services/monitor/index.ts",
    "build": "tsc",
    "start": "node dist/api/index.js",
    "start:liquidator": "node dist/services/liquidator/index.js",
    "start:monitor": "node dist/services/monitor/index.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "viem": "^2.25.0",
    "drizzle-orm": "^0.39.0",
    "postgres": "^3.4.0",
    "bullmq": "^5.30.0",
    "ioredis": "^5.4.0",
    "pino": "^9.6.0",
    "@liquidlp/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "drizzle-kit": "^0.30.0",
    "@types/node": "^22.0.0"
  }
}
