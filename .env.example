# RPC URLs (DRPC recommended — get key at drpc.org)
DRPC_KEY=YOUR_DRPC_KEY
ETH_RPC_URL=https://lb.drpc.org/ogrpc?network=ethereum&dkey=${DRPC_KEY}
BASE_RPC_URL=https://lb.drpc.org/ogrpc?network=base&dkey=${DRPC_KEY}
ARB_RPC_URL=https://lb.drpc.org/ogrpc?network=arbitrum&dkey=${DRPC_KEY}
BSC_RPC_URL=https://lb.drpc.org/ogrpc?network=bsc&dkey=${DRPC_KEY}
POLYGON_RPC_URL=https://lb.drpc.org/ogrpc?network=polygon&dkey=${DRPC_KEY}

# Testnet RPCs
SEPOLIA_RPC_URL=https://lb.drpc.org/ogrpc?network=sepolia&dkey=${DRPC_KEY}
BASE_SEPOLIA_RPC_URL=https://lb.drpc.org/ogrpc?network=base-sepolia&dkey=${DRPC_KEY}

# Block Explorer API Keys
ETHERSCAN_KEY=
BASESCAN_KEY=
ARBISCAN_KEY=

# Deployer (NEVER commit real keys)
DEPLOYER_PRIVATE_KEY=

# Backend
DATABASE_URL=postgresql://liquidlp:localdev@localhost:5432/liquidlp
REDIS_URL=redis://localhost:6379

# Monitoring
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Frontend
